---
import PageLayout from '../layouts/PageLayout.astro';
import CardGrid from '../components/CardGrid.astro';
import ToolCard from '../components/ToolCard.astro';
import CategorySection from '../components/CategorySection.astro';
import { url } from '../lib/utils';
import { getCollection } from 'astro:content';

const pickTop = (items: any[], n = 6) => {
  const sorted = items.sort((a, b) => (b.data.recommended ? 1 : 0) - (a.data.recommended ? 1 : 0) || a.data.order - b.data.order);
  const recommended = sorted.filter(e => e.data.recommended);
  const featured = sorted.filter(e => !e.data.recommended && e.data.featured);
  return [...recommended, ...featured].slice(0, n);
};

const emulators = pickTop(await getCollection('emulators'));
const shells = pickTop(await getCollection('shells'));
const tools = pickTop(await getCollection('tools'));
const themes = pickTop(await getCollection('themes'));
const configs = pickTop(await getCollection('configs'));
const fonts = pickTop(await getCollection('fonts'));

const totalEmulators = (await getCollection('emulators')).length;
const totalShells = (await getCollection('shells')).length;
const totalConfigs = (await getCollection('configs')).length;
const totalThemes = (await getCollection('themes')).length;
const totalTools = (await getCollection('tools')).length;
const totalFonts = (await getCollection('fonts')).length;
const totalEntries = totalEmulators + totalShells + totalConfigs + totalThemes + totalTools + totalFonts;
---

<PageLayout title="Terminal 百科 — 终端工具导航" description="一站式终端工具导航百科，涵盖终端模拟器、Shell、配置、主题、CLI 工具和编程字体">
  <!-- Hero -->
  <section class="text-center py-10 md:py-14">
    <h1 class="text-4xl md:text-6xl font-bold font-mono mb-4">
      <span class="dark:text-terminal-green text-terminal-green">$</span>
      <span class="dark:text-terminal-heading text-light-heading"> Terminal</span>
      <span class="dark:text-terminal-purple text-terminal-purple"> 百科</span>
    </h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto dark:text-terminal-fg/80 text-light-fg/80 mb-6">
      一站式终端工具导航 — 终端模拟器、Shell、经典配置、主题美化、CLI 工具、编程字体
    </p>
    <div class="font-mono text-sm dark:text-terminal-fg/50 text-light-fg/50 mb-8">
      <span class="dark:text-terminal-green text-terminal-green">~</span> 探索现代终端的无限可能
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-6 text-sm font-mono">
      <span class="dark:text-terminal-fg/60 text-light-fg/60">
        共收录 <span class="dark:text-terminal-green text-terminal-green font-semibold">{totalEntries}</span> 个条目
      </span>
      <span class="dark:text-terminal-fg/40 text-light-fg/40">|</span>
      <span class="dark:text-terminal-fg/60 text-light-fg/60">6 大分类</span>
      <span class="dark:text-terminal-fg/40 text-light-fg/40">|</span>
      <span class="dark:text-terminal-fg/60 text-light-fg/60">持续更新中</span>
    </div>
  </section>

  <!-- Category Quick Links -->
  <section class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-16">
    <a href={url('/emulators')} class="group p-6 rounded-xl border transition-all no-underline
      dark:bg-terminal-surface/50 dark:border-terminal-border dark:hover:border-terminal-green/50
      bg-light-surface border-light-border hover:border-terminal-green/50
      hover:shadow-lg hover:shadow-terminal-green/5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">🖥️</span>
        <span class="text-xs font-mono dark:text-terminal-fg/40 text-light-fg/40">{totalEmulators}</span>
      </div>
      <h3 class="font-semibold dark:text-terminal-heading text-light-heading text-base">终端模拟器</h3>
      <p class="text-sm dark:text-terminal-fg/60 text-light-fg/60 mt-1">iTerm2, Alacritty, Kitty...</p>
    </a>
    <a href={url('/shells')} class="group p-6 rounded-xl border transition-all no-underline
      dark:bg-terminal-surface/50 dark:border-terminal-border dark:hover:border-terminal-blue/50
      bg-light-surface border-light-border hover:border-terminal-blue/50
      hover:shadow-lg hover:shadow-terminal-blue/5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">⚡</span>
        <span class="text-xs font-mono dark:text-terminal-fg/40 text-light-fg/40">{totalShells}</span>
      </div>
      <h3 class="font-semibold dark:text-terminal-heading text-light-heading text-base">Shell</h3>
      <p class="text-sm dark:text-terminal-fg/60 text-light-fg/60 mt-1">Zsh, Bash, Fish, Nushell...</p>
    </a>
    <a href={url('/configs')} class="group p-6 rounded-xl border transition-all no-underline
      dark:bg-terminal-surface/50 dark:border-terminal-border dark:hover:border-terminal-purple/50
      bg-light-surface border-light-border hover:border-terminal-purple/50
      hover:shadow-lg hover:shadow-terminal-purple/5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">⚙️</span>
        <span class="text-xs font-mono dark:text-terminal-fg/40 text-light-fg/40">{totalConfigs}</span>
      </div>
      <h3 class="font-semibold dark:text-terminal-heading text-light-heading text-base">经典配置</h3>
      <p class="text-sm dark:text-terminal-fg/60 text-light-fg/60 mt-1">.zshrc, tmux.conf, init.lua...</p>
    </a>
    <a href={url('/themes')} class="group p-6 rounded-xl border transition-all no-underline
      dark:bg-terminal-surface/50 dark:border-terminal-border dark:hover:border-terminal-cyan/50
      bg-light-surface border-light-border hover:border-terminal-cyan/50
      hover:shadow-lg hover:shadow-terminal-cyan/5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">🎨</span>
        <span class="text-xs font-mono dark:text-terminal-fg/40 text-light-fg/40">{totalThemes}</span>
      </div>
      <h3 class="font-semibold dark:text-terminal-heading text-light-heading text-base">主题美化</h3>
      <p class="text-sm dark:text-terminal-fg/60 text-light-fg/60 mt-1">Catppuccin, Dracula, Nord...</p>
    </a>
    <a href={url('/tools')} class="group p-6 rounded-xl border transition-all no-underline
      dark:bg-terminal-surface/50 dark:border-terminal-border dark:hover:border-terminal-yellow/50
      bg-light-surface border-light-border hover:border-terminal-yellow/50
      hover:shadow-lg hover:shadow-terminal-yellow/5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">🔧</span>
        <span class="text-xs font-mono dark:text-terminal-fg/40 text-light-fg/40">{totalTools}</span>
      </div>
      <h3 class="font-semibold dark:text-terminal-heading text-light-heading text-base">CLI 工具</h3>
      <p class="text-sm dark:text-terminal-fg/60 text-light-fg/60 mt-1">fzf, ripgrep, bat, fd...</p>
    </a>
    <a href={url('/fonts')} class="group p-6 rounded-xl border transition-all no-underline
      dark:bg-terminal-surface/50 dark:border-terminal-border dark:hover:border-terminal-orange/50
      bg-light-surface border-light-border hover:border-terminal-orange/50
      hover:shadow-lg hover:shadow-terminal-orange/5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">🔤</span>
        <span class="text-xs font-mono dark:text-terminal-fg/40 text-light-fg/40">{totalFonts}</span>
      </div>
      <h3 class="font-semibold dark:text-terminal-heading text-light-heading text-base">编程字体</h3>
      <p class="text-sm dark:text-terminal-fg/60 text-light-fg/60 mt-1">JetBrains Mono, Fira Code...</p>
    </a>
  </section>

  <!-- Featured Emulators -->
  <CategorySection title="精选终端模拟器" href={url('/emulators')}>
    <CardGrid>
      {emulators.map(entry => <ToolCard entry={entry} collection="emulators" />)}
    </CardGrid>
  </CategorySection>

  <!-- Featured Shells -->
  <CategorySection title="热门 Shell" href={url('/shells')}>
    <CardGrid>
      {shells.map(entry => <ToolCard entry={entry} collection="shells" />)}
    </CardGrid>
  </CategorySection>

  <!-- Featured Tools -->
  <CategorySection title="必备 CLI 工具" href={url('/tools')}>
    <CardGrid>
      {tools.map(entry => <ToolCard entry={entry} collection="tools" />)}
    </CardGrid>
  </CategorySection>

  <!-- Featured Themes -->
  <CategorySection title="流行主题" href={url('/themes')}>
    <CardGrid>
      {themes.map(entry => <ToolCard entry={entry} collection="themes" />)}
    </CardGrid>
  </CategorySection>

  <!-- Featured Configs -->
  <CategorySection title="经典配置" href={url('/configs')}>
    <CardGrid>
      {configs.map(entry => <ToolCard entry={entry} collection="configs" />)}
    </CardGrid>
  </CategorySection>

  <!-- Featured Fonts -->
  <CategorySection title="推荐字体" href={url('/fonts')}>
    <CardGrid>
      {fonts.map(entry => <ToolCard entry={entry} collection="fonts" />)}
    </CardGrid>
  </CategorySection>
</PageLayout>
